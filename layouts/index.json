{{- $pages := where .Site.RegularPages "Section" "in" (slice "science" "values" "journal") -}}
[
  {{- range $i, $p := $pages -}}
  {{- if $i }},{{ end -}}
  {
    "title": {{ $p.Title | jsonify }},
    "url": {{ $p.RelPermalink | jsonify }},
    "section": {{ $p.Section | jsonify }},
    "summary": {{ or $p.Params.summary $p.Params.description "" | jsonify }}
  }
  {{- end -}}
]
